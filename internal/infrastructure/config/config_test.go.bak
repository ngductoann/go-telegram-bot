package config

import (
	"os"
	"testing"

	"github.com/stretchr/testify/assert"
	"github.com/stretchr/testify/require"
)

func TestLoadConfig(t *testing.T) {
	tests := []struct {
		name        string
		setupEnv    func()
		cleanupEnv  func()
		expectError bool
		validate    func(*testing.T, *Config)
	}{
		{
			name: "default configuration",
			setupEnv: func() {
				os.Setenv("BOT_TOKEN", "test_token")
			},
			cleanupEnv: func() {
				os.Unsetenv("BOT_TOKEN")
			},
			expectError: false,
			validate: func(t *testing.T, cfg *Config) {
				assert.Equal(t, "test_token", cfg.GetBotToken())
				assert.Equal(t, DefaultEnvironment, cfg.GetEnvironment())
				assert.Equal(t, DefaultDBHost, cfg.Database.Host)
				assert.Equal(t, DefaultDBPort, cfg.Database.Port)
			},
		},
		{
			name: "missing bot token",
			setupEnv: func() {
				// Don't set BOT_TOKEN
			},
			cleanupEnv:  func() {},
			expectError: true,
		},
		{
			name: "custom environment variables",
			setupEnv: func() {
				os.Setenv("BOT_TOKEN", "custom_token")
				os.Setenv("ENVIRONMENT", "production")
				os.Setenv("DB_HOST", "custom_host")
				os.Setenv("DB_PORT", "3306")
			},
			cleanupEnv: func() {
				os.Unsetenv("BOT_TOKEN")
				os.Unsetenv("ENVIRONMENT")
				os.Unsetenv("DB_HOST")
				os.Unsetenv("DB_PORT")
			},
			expectError: false,
			validate: func(t *testing.T, cfg *Config) {
				assert.Equal(t, "custom_token", cfg.GetBotToken())
				assert.Equal(t, "production", cfg.GetEnvironment())
				assert.True(t, cfg.IsProduction())
				assert.False(t, cfg.IsDevelopment())
				assert.Equal(t, "custom_host", cfg.Database.Host)
				assert.Equal(t, 3306, cfg.Database.Port)
			},
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			// Setup
			tt.setupEnv()
			defer tt.cleanupEnv()

			// Test
			cfg, err := LoadConfig()

			// Validate
			if tt.expectError {
				assert.Error(t, err)
				assert.Nil(t, cfg)
			} else {
				require.NoError(t, err)
				require.NotNil(t, cfg)
				if tt.validate != nil {
					tt.validate(t, cfg)
				}
			}
		})
	}
}

func TestConfig_GetDatabaseURL(t *testing.T) {
	cfg := &Config{
		Database: Database{
			Host:     "localhost",
			Port:     5432,
			User:     "testuser",
			Password: "testpass",
			Name:     "testdb",
			SSLMode:  "disable",
		},
	}

	expected := "host=localhost port=5432 user=testuser password=testpass dbname=testdb sslmode=disable"
	assert.Equal(t, expected, cfg.GetDatabaseURL())
}

func TestConfig_GetRedisURL(t *testing.T) {
	tests := []struct {
		name     string
		config   Redis
		expected string
	}{
		{
			name: "with password",
			config: Redis{
				Host:     "localhost",
				Port:     "6379",
				Password: "secret",
				DB:       1,
			},
			expected: "redis://:secret@localhost:6379/1",
		},
		{
			name: "without password",
			config: Redis{
				Host: "localhost",
				Port: "6379",
				DB:   0,
			},
			expected: "redis://localhost:6379/0",
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			cfg := &Config{Redis: tt.config}
			assert.Equal(t, tt.expected, cfg.GetRedisURL())
		})
	}
}

func TestConfig_EnvironmentCheckers(t *testing.T) {
	tests := []struct {
		name          string
		environment   string
		isDevelopment bool
		isProduction  bool
	}{
		{"development", "development", true, false},
		{"production", "production", false, true},
		{"staging", "staging", false, false},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			cfg := &Config{
				App: App{Environment: tt.environment},
			}

			assert.Equal(t, tt.isDevelopment, cfg.IsDevelopment())
			assert.Equal(t, tt.isProduction, cfg.IsProduction())
		})
	}
}

func TestConfigLoader_Validation(t *testing.T) {
	loader := newConfigLoader()

	tests := []struct {
		name        string
		config      *Config
		expectError bool
		errorMsg    string
	}{
		{
			name: "valid config",
			config: &Config{
				App: App{BotToken: "valid_token"},
				Database: Database{
					Host: "localhost",
					Port: 5432,
				},
			},
			expectError: false,
		},
		{
			name: "missing bot token",
			config: &Config{
				App: App{BotToken: ""},
				Database: Database{
					Host: "localhost",
					Port: 5432,
				},
			},
			expectError: true,
			errorMsg:    "BOT_TOKEN is required",
		},
		{
			name: "invalid database port",
			config: &Config{
				App: App{BotToken: "valid_token"},
				Database: Database{
					Host: "localhost",
					Port: -1,
				},
			},
			expectError: true,
			errorMsg:    "database port must be positive",
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			err := loader.validate(tt.config)

			if tt.expectError {
				assert.Error(t, err)
				if tt.errorMsg != "" {
					assert.Contains(t, err.Error(), tt.errorMsg)
				}
			} else {
				assert.NoError(t, err)
			}
		})
	}
}
